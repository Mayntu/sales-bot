TELEGRAM_BOT_TOKEN=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# только этап NEW (привет); QUALIFY и дальше — OPENAI_MODEL
OPENAI_MODEL_LIGHT=gpt-4o-mini

DATABASE_URL=postgresql+asyncpg://gymbot:gymbot@db:5432/gymbot
REDIS_URL=redis://redis:6379/0

MANAGER_API_SECRET=
ADMIN_SECRET=change-me
# chat_id админов через запятую (личка → твой user id). То же нужно сервису API для /admin/refresh-user и /admin/user-state.
# Подойдёт ADMIN_CHAT_IDS или ADMIN_TELEGRAM_CHAT_IDS.
ADMIN_CHAT_IDS=
MANAGER_CHAT_ID=

# transport bot -> api
API_INTERNAL_URL=http://api:8000

# webhook secret (if later webhook mode is used)
WEBHOOK_SECRET=
WEBHOOK_URL=

CLUB_INFO_PATH=club_data/club_info.yaml

# Agent names shown to clients (comma-separated). One per user, assigned deterministically.
AGENT_NAMES=Саша,Данияр,Толкын
